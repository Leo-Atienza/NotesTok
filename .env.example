# Google Gemini API Key (required)
# Get yours free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (optional — enables media asset database + voiceover cache)
# Create a project at: https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Pexels API (optional — enables stock video/photo backgrounds)
# Get a free key at: https://www.pexels.com/api/new/
PEXELS_API_KEY=

# ElevenLabs TTS (optional — enables AI voiceover)
# Free tier at: https://elevenlabs.io
ELEVENLABS_API_KEY=

# Klipy GIF API (optional — enables reaction GIF overlays in videos)
# Free tier (100 req/min) at: https://klipy.com
KLIPY_API_KEY=

# Pixabay API (optional — supplements Pexels with additional stock media)
# Free tier (100 req/min) at: https://pixabay.com/api/docs/
PIXABAY_API_KEY=
